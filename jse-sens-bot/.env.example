SENS_BASE_URL=https://clientportal.jse.co.za/communication/sens-announcements
SENS_PDF_BASE_URL=https://senspdf.jse.co.za/
SENS_REQUEST_TIMEOUT=30
SENS_DOWNLOAD_RETRIES=3
SENS_DOWNLOAD_BACKOFF_SECONDS=1.0
SENS_SCRAPE_MAX_ATTEMPTS=2
SENS_SCRAPE_RETRY_BACKOFF_SECONDS=2.0
SENS_SCRAPE_DOM_ALERT_MAX_RAW_CANDIDATES=2
SENS_REQUEST_USER_AGENT=jse-sens-bot/1.0 (+local-staging)
SENS_ALLOWED_PDF_HOSTS=senspdf.jse.co.za
# Keep weekend skip enabled for production/staging.
SENS_SKIP_WEEKENDS=1
SENS_SCRAPE_INTERVAL_MINUTES=5
SENS_SCHEDULER_WEEKDAY_PREOPEN_MINUTES=10
SENS_SCHEDULER_WEEKDAY_MARKET_MINUTES=5
SENS_SCHEDULER_WEEKDAY_AFTERCLOSE_MINUTES=10
SENS_SCHEDULER_WEEKDAY_OFFHOURS_MINUTES=60
SENS_SCHEDULER_WEEKEND_MINUTES=360
SENS_SCHEDULER_JITTER_SECONDS=45
SENS_SCHEDULER_MAX_COOLDOWN_MULTIPLIER=8
SENS_DATA_DIR=./mvp_sens/data
SENS_PDF_DIR=./mvp_sens/data/pdfs
SENS_PARSED_TEXT_DIR=./mvp_sens/data/parsed
SENS_EXPORT_DIR=./mvp_sens/data/exports
SENS_DB_PATH=./mvp_sens/db/sens.db
SENS_SCHEMA_PATH=./mvp_sens/db/schema.sql
